# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.turbo/

# Stale TypeScript build artifacts in source dirs (Vite picks .js over .tsx)
apps/web/src/**/*.js
apps/web/src/**/*.js.map
apps/web/src/**/*.d.ts
apps/web/src/**/*.d.ts.map

# Emitted vite config artifacts — source is vite.config.ts; a stray `tsc -b`
# emits vite.config.js which Vite loads in preference to the .ts.
# (tailwind.config.js / postcss.config.js are hand-written sources — keep those.)
apps/web/vite.config.js
apps/web/vite.config.js.map
apps/web/vite.config.d.ts
apps/web/vite.config.d.ts.map

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Environment
.env
.env.*

# Secrets — never commit these
secrets/

# Test coverage
coverage/

# Logs
*.log
npm-debug.log*

# Temp files
*.tmp
tmpclaude-*

# Per-user Claude Code local settings (skills/ stay tracked)
.claude/settings.local.json
